# ─────────────────────────────────────────────────────────────
# Root catalog of every env var used across the monorepo.
# Each app reads from its own apps/<app>/.env file at runtime
# (see apps/*/.env.example for the per-app templates).
# This file is documentation only.
# ─────────────────────────────────────────────────────────────

# ============ apps/api (Express backend) ============
PORT=4000
DB_URI=mongodb+srv://<user>:<pass>@<cluster>/<db>
JWT_SECRET=replace-me

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

APPWRITE_ENDPOINT=
APPWRITE_PROJECT_ID=
APPWRITE_SERVER_KEY=
APPWRITE_DATABASE_ID=
APPWRITE_COLLECTION_ID=
APPWRITE_BUCKET_ID=

GOOGLE_GEMINI_API_KEY=

EMAIL_USER=
EMAIL_PASS=

# ============ apps/web (Vite landing site) ============
VITE_API_BASE_URL=http://localhost:4000/api

# ============ apps/admin (CRA admin panel) ============
REACT_APP_BASE_URL=http://localhost:4000/api
REACT_APP_EMAIL_SERVER=
