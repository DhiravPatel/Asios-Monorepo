APPWRITE_DATABASE_ID=
APPWRITE_COLLECTION_ID=
APPWRITE_BUCKET_ID=

# Google Gemini
GOOGLE_GEMINI_API_KEY=

# SMTP (nodemailer)
EMAIL_USER=
EMAIL_PASS=
